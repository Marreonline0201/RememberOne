<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Native Sign in with Apple (ASAuthorizationController). Requires the
	     "Sign In with Apple" capability on the App ID com.rememberone.app so
	     the fetched provisioning profile carries this entitlement. -->
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
</dict>
</plist>
